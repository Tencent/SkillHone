{
  // ---------------------------------------------------------------------------
  // ~/.skillhone/settings.json — SkillHone global config.
  //
  // Usage: copy this file to ~/.skillhone/settings.json, then fill the fields.
  //   mkdir -p ~/.skillhone
  //   cp assets/settings.json ~/.skillhone/settings.json
  //
  // JSON5 syntax is supported (comments + trailing commas) when the `json5`
  // Python package is installed. If you only have the stdlib `json`, strip the
  // comments and trailing commas before use.
  // ---------------------------------------------------------------------------

  // -- Anthropic API key (used by the improver to call Claude) --
  // If you route through a third-party Anthropic-compatible proxy (api_base
  // is not api.anthropic.com), put the proxy's key here instead.
  "api_key": "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",

  // -- Forgejo Git server --
  "forgejo": {
    // HTTP URL of your Forgejo instance (no trailing slash).
    // Default for the bundled docker-compose is http://localhost:3000.
    "url": "http://localhost:3000",

    // Owner account that holds every skill/eval repo (typically a dedicated
    // service account, e.g. "skillhone").
    "owner": "skillhone",

    // Personal Access Token with repo read/write permission.
    // Create at: Forgejo -> avatar -> Settings -> Applications -> Generate Token.
    // Required scopes: repo (read/write) + issue (read/write) + pull-request
    // (read/write).
    "token": "your_forgejo_personal_access_token"
  },

  // -- Improver config (the Claude agent driving the optim.py loop) --
  "improver": {
    // Claude API base URL. Leave empty to use the official endpoint
    // https://api.anthropic.com.
    "api_base": "",

    // Model used for the improvement loop. Stronger models give better
    // results; Opus-class is recommended.
    "model": "claude-opus-4-5",

    // Max conversation turns per agent session. Setting this too low will
    // truncate the loop mid-iteration.
    "max_turns": 100,

    // Extra env vars passed into the improver agent process. These override
    // the top-level api_base / api_key when set.
    "env": {
      "ANTHROPIC_BASE_URL": "",   // empty -> inherit api_base
      "ANTHROPIC_API_KEY": ""     // empty -> inherit top-level api_key
    }
  },

  // -- Executor config (the model that runs the skill being tested in eval.py) --
  "executor": {
    // Executor API base URL. Leave empty to use the official endpoint.
    "api_base": "",

    // Executor model name; this is the "solver" that answers each probe.
    // Examples: claude-haiku-4-5 (cheap + fast), claude-sonnet-4-5 (higher
    // accuracy).
    "model": "claude-haiku-4-5",

    // sdk_model_alias maps to the Claude Agent SDK tier (haiku / sonnet /
    // opus). If you use an official model, set the matching tier. If you
    // route through a custom proxy, this must agree with env.ANTHROPIC_MODEL.
    "sdk_model_alias": "haiku",

    // Concurrent workers (one per probe item). Too high will trip API
    // rate limits.
    "workers": 8,

    // Max solver steps per item.
    "max_iterations": 150,

    // Enable extended thinking.
    "thinking_enabled": true,

    // Context window (in tokens). 32000+ recommended.
    "context_size": 40000,

    // Sampling parameters — fill these in based on what your API supports.
    // When unsure, keep the defaults.
    "temperature": 1.0,
    "top_p": 0.95,
    "top_k": 20,
    "presence_penalty": 1.5,

    // Process pool to speed up CLI startup. Set to false if you hit pool
    // instability.
    "enable_process_pool": true,
    "process_pool_size": 16,
    "pool_initialization_batch_size": 4,
    "pool_bare_mode": true,

    // Extra env vars passed into each solver process.
    "env": {
      "ANTHROPIC_BASE_URL": "",
      "ANTHROPIC_API_KEY": "",
      // When sdk_model_alias=haiku, ANTHROPIC_DEFAULT_HAIKU_MODEL must point
      // to the actual model name your provider serves.
      "ANTHROPIC_MODEL": "claude-haiku-4-5",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5"
    }
  },

  // -- Synthesis config (used when generating eval data; optional) --
  "synthesis": {
    "api_base": "",
    "model": "claude-sonnet-4-5",
    "workers": 8
  }
}
